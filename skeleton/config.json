{
  "email": {
    "server": {
      "host": "smtp.example.com",
      "port": 587,
      "password": "your-password-here",
      "email": "you@example.com"
    }
  },
  "defs": {
    "hackernews": {
      "url": "https://news.ycombinator.com",
      "pagination": {
        "type": "next_link",
        "selector": "a.morelink",
        "base_url": "https://news.ycombinator.com/",
        "max_pages": 2
      },
      "query": {
        "type": "list",
        "selector": "tr.athing.submission",
        "id": {
          "type": "attribute",
          "name": "id"
        },
        "variables": {
          "title": {
            "selector": ".titleline > a",
            "value": {
              "type": "text"
            }
          },
          "url": {
            "selector": ".titleline > a",
            "value": {
              "type": "attribute",
              "name": "href"
            }
          },
          "rank": {
            "selector": ".rank",
            "value": {
              "type": "text"
            },
            "default": ""
          },
          "score": {
            "sibling": true,
            "selector": ".score",
            "value": {
              "type": "text"
            },
            "default": "0 points"
          },
          "age": {
            "sibling": true,
            "selector": ".age a",
            "value": {
              "type": "text"
            },
            "default": ""
          },
          "comments_url": {
            "sibling": true,
            "selector": ".age a",
            "value": {
              "type": "attribute",
              "name": "href",
              "prefix": "https://news.ycombinator.com/"
            },
            "default": ""
          }
        }
      }
    }
  },
  "rules": [
    {
      "ref": "hackernews",
      "name": "hackernews",
      "schedule": "0 */6 * * *",
      "subject": "Hacker News: {{count}} new stories",
      "template": "./templates/hackernews",
      "email": "you@example.com"
    }
  ]
}
